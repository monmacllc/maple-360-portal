            </div>
            <div style={{background:"#FDEEE6",borderRadius:"10px",padding:"24px 22px",borderTop:"3px solid #FFD93D"}}>
              <h3 style={{fontFamily:"Georgia, serif",fontSize:"16px",fontWeight:"bold",color:"#E8548C",margin:"0 0 10px"}}>
