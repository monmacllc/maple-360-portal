"use client";

export default function ISLPitchDeck() {
  return (
    <main>
      <section aria-label="Course introduction and free download" style={{background:"linear-gradient(160deg, #FFF9F5 0%, #FDEEE6 100%)",padding:"72px 24px 80px",textAlign:"center"}}>
        <div style={{maxWidth:"760px",margin:"0 auto"}}>
