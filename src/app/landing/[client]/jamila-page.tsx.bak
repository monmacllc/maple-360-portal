              </div>
              <p style={{marginTop:"12px",fontSize:"13px",color:"#8B7B72",textAlign:"center",lineHeight:"1.5"}}>
                Free PDF delivered to your inbox. No spam, ever. Unsubscribe anytime.
              </p>
            </form>
          </div>
        </div>
